# Sync .project/sourceTexts/ folder (source text files)

# Don't sync user-specific SQLite databases
.project/*.sqlite

# Don't sync SQLite auxiliary files
.project/*.sqlite-wal
.project/*.sqlite-shm

# Don't sync user-specific files
.project/complete_drafts.txt
.project/localProjectSettings.json
.project/localProjectSwap.json
copilot-messages.log

# Archive formats
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.bz2
*.xz

# Windows executables and installers
*.exe
*.msi
*.bat
*.cmd
*.com
*.scr
*.dll

# macOS executables and disk images
*.dmg
*.pkg

# Disk images and virtual machine files
*.iso
*.img
*.vhd
*.vmdk

# System files
.DS_Store
.project/attachments/files/**

# Local runtime databases for figma app
figma/prisma/dev.db
figma/prisma/dev.db-journal
figma/prisma/dev.db-shm
figma/prisma/dev.db-wal
figma/tsconfig.tsbuildinfo

# Node / Next build artifacts
node_modules/
**/node_modules/
.next/
**/.next/
dist/
coverage/

# Env files
.env
.env.local
.env.*.local

# Local tool metadata
.project/
files/
.vscode/
